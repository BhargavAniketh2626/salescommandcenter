<core:FragmentDefinition
xmlns="sap.m"
xmlns:core="sap.ui.core"
xmlns:viz="sap.viz.ui5.controls"
xmlns:viz.data="sap.viz.ui5.data"
xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

<Dialog
id="chartDetailsDialog"
title="Detailed Sales Analysis"
stretch="true">

<VBox class="sapUiMediumMargin">

<viz:VizFrame
id="detailChart"
vizType="stacked_bar"
height="500px"
uiConfig="{applicationSet:'fiori'}">

<viz:dataset>

<viz.data:FlattenedDataset>

<viz.data:data path="/Orders"/>

<viz.data:dimensions>
<viz.data:DimensionDefinition
name="OrderID"
value="{OrderID}"/>
</viz.data:dimensions>

<viz.data:measures>
<viz.data:MeasureDefinition
name="Freight"
value="{Freight}"/>
</viz.data:measures>

</viz.data:FlattenedDataset>

</viz:dataset>

<viz:feeds>

<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Freight"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="OrderID"/>

</viz:feeds>

</viz:VizFrame>

</VBox>

<endButton>
<Button text="Close" press="onClose"/>
</endButton>

</Dialog>

</core:FragmentDefinition>