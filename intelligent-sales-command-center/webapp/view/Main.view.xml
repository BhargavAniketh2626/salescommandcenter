<mvc:View
controllerName="com.sales.commandcenter.intelligentsalescommandcenter.controller.Main"
xmlns:mvc="sap.ui.core.mvc"
xmlns="sap.m"
xmlns:f="sap.f"
xmlns:viz="sap.viz.ui5.controls"
xmlns:viz.data="sap.viz.ui5.data"
xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">

<f:DynamicPage>

<f:title>
<f:DynamicPageTitle>
<f:heading>
<Title text="Intelligent Sales Command Center"/>
</f:heading>
</f:DynamicPageTitle>
</f:title>

<f:content>

<VBox class="sapUiMediumMargin">

<!-- KPI -->

<HBox justifyContent="SpaceAround" class="sapUiMediumMarginBottom">

<ObjectStatus text="PC 758K" state="Success"/>
<ObjectStatus text="PM 28.4%" state="Error"/>
<ObjectStatus text="PR 973K" state="Success"/>

</HBox>

<!-- Charts -->

<HBox justifyContent="SpaceBetween">

<!-- Margin Chart -->

<viz:VizFrame
id="marginChart"
vizType="line"
height="260px"
width="33%"
uiConfig="{applicationSet:'fiori'}">

<viz:dataset>

<viz.data:FlattenedDataset>

<viz.data:data path="/Orders"/>

<viz.data:dimensions>
<viz.data:DimensionDefinition
name="OrderDate"
value="{OrderDate}"/>
</viz.data:dimensions>

<viz.data:measures>
<viz.data:MeasureDefinition
name="Freight"
value="{Freight}"/>
</viz.data:measures>

</viz.data:FlattenedDataset>

</viz:dataset>

<viz:feeds>

<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Freight"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="OrderDate"/>

</viz:feeds>

</viz:VizFrame>



<!-- Revenue Chart -->

<viz:VizFrame
id="salesChart"
vizType="bar"
height="260px"
width="33%"
uiConfig="{applicationSet:'fiori'}">

<viz:dataset>

<viz.data:FlattenedDataset>

<viz.data:data path="/Products"/>

<viz.data:dimensions>
<viz.data:DimensionDefinition
name="Product"
value="{ProductName}"/>
</viz.data:dimensions>

<viz.data:measures>
<viz.data:MeasureDefinition
name="UnitPrice"
value="{UnitPrice}"/>
</viz.data:measures>

</viz.data:FlattenedDataset>

</viz:dataset>

<viz:feeds>

<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="UnitPrice"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Product"/>

</viz:feeds>

</viz:VizFrame>



<!-- Donut -->

<viz:VizFrame
id="donutChart"
vizType="donut"
height="260px"
width="33%"
uiConfig="{applicationSet:'fiori'}">

<viz:dataset>

<viz.data:FlattenedDataset>

<viz.data:data path="/Order_Details"/>

<viz.data:dimensions>
<viz.data:DimensionDefinition
name="ProductID"
value="{ProductID}"/>
</viz.data:dimensions>

<viz.data:measures>
<viz.data:MeasureDefinition
name="Quantity"
value="{Quantity}"/>
</viz.data:measures>

</viz.data:FlattenedDataset>

</viz:dataset>

<viz:feeds>

<viz.feeds:FeedItem uid="size" type="Measure" values="Quantity"/>
<viz.feeds:FeedItem uid="color" type="Dimension" values="ProductID"/>

</viz:feeds>

</viz:VizFrame>

</HBox>



<!-- Employee Chart -->

<viz:VizFrame
id="employeeChart"
vizType="column"
height="300px"
uiConfig="{applicationSet:'fiori'}"
class="sapUiMediumMarginTop">

<viz:dataset>

<viz.data:FlattenedDataset>

<viz.data:data path="/Employees"/>

<viz.data:dimensions>
<viz.data:DimensionDefinition
name="Employee"
value="{LastName}"/>
</viz.data:dimensions>

<viz.data:measures>
<viz.data:MeasureDefinition
name="EmployeeID"
value="{EmployeeID}"/>
</viz.data:measures>

</viz.data:FlattenedDataset>

</viz:dataset>

<viz:feeds>

<viz.feeds:FeedItem uid="valueAxis" type="Measure" values="EmployeeID"/>
<viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Employee"/>

</viz:feeds>

</viz:VizFrame>



<!-- Orders Table -->

<!-- Orders Section -->

<VBox class="sapUiMediumMarginTop">

<!-- Toolbar -->

<OverflowToolbar>

<Title text="Orders"/>

<ToolbarSpacer/>

<SearchField
width="300px"
placeholder="Search Orders"/>

<Button
icon="sap-icon://sort"
text="Sort"/>

<Button
icon="sap-icon://filter"
text="Filter"/>

<Button
icon="sap-icon://refresh"
text="Refresh"/>

</OverflowToolbar>


<Table
id="ordersTable"
items="{/Orders}"
growing="true"
growingScrollToLoad="true"
growingThreshold="20">

<columns>

<Column
sortProperty="OrderID"
filterProperty="OrderID">

<Text text="Order ID"/>

</Column>

<Column
sortProperty="CustomerID"
filterProperty="CustomerID">

<Text text="Customer"/>

</Column>

<Column
sortProperty="OrderDate"
filterProperty="OrderDate">

<Text text="Date"/>

</Column>

<Column
sortProperty="Freight"
filterProperty="Freight">

<Text text="Freight"/>

</Column>

</columns>


<items>

<ColumnListItem>

<cells>

<Text text="{OrderID}"/>
<Text text="{CustomerID}"/>
<Text text="{OrderDate}"/>
<ObjectNumber number="{Freight}"/>

</cells>

</ColumnListItem>

</items>

</Table>

</VBox>
</VBox>

</f:content>

</f:DynamicPage>

</mvc:View>