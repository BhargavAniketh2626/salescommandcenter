{
  "_version": "1.82.0",

  "sap.app": {
    "id": "com.sales.commandcenter.intelligentsalescommandcenter",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",

    "dataSources": {
      "northwind": {
        "uri": "/v2/northwind/northwind.svc/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0"
        }
      }
    }
  },

  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },

  "sap.ui5": {
    "flexEnabled": false,

    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.viz": {},
        "sap.f": {}
      }
    },

    "contentDensities": {
      "compact": true,
      "cozy": true
    },

    "models": {
      "": {
        "dataSource": "northwind",
        "type": "sap.ui.model.odata.v2.ODataModel",
        "settings": {
          "defaultBindingMode": "TwoWay",
          "useBatch": false
        }
      },

      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.sales.commandcenter.intelligentsalescommandcenter.i18n.i18n"
        }
      }
    },

    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },

    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.sales.commandcenter.intelligentsalescommandcenter.view",
        "async": true
      },

      "routes": [
        {
          "name": "RouteMain",
          "pattern": ":?query:",
          "target": ["TargetMain"]
        }
      ],

      "targets": {
        "TargetMain": {
          "id": "Main",
          "name": "Main"
        }
      }
    },

    "rootView": {
      "viewName": "com.sales.commandcenter.intelligentsalescommandcenter.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}